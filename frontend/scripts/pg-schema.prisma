generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/pg-export-client"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id           String    @id @db.Uuid
  name         String
  slug         String    @unique
  supportEmail String?   @map("support_email")
  supportPhone String?   @map("support_phone")
  logoUrl      String?   @map("logo_url")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  products     Product[]
  profiles     Profile[]

  @@map("stores")
}

model Profile {
  id        String     @id @db.Uuid
  storeId   String?    @map("store_id") @db.Uuid
  email     String?    @unique
  fullName  String?    @map("full_name")
  phone     String?
  role      UserRole   @default(customer)
  avatarUrl String?    @map("avatar_url")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  store     Store?     @relation(fields: [storeId], references: [id])
  reviews   Review[]
  wishlists Wishlist[]

  @@map("profiles")
}

model SiteSettings {
  key         String   @id
  value       Json     @default("{}")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_settings")
}

model NavigationLink {
  id        String      @id @db.Uuid
  kind      NavLinkKind
  label     String
  href      String
  icon      String?
  badgeText String?     @map("badge_text")
  sortOrder Int         @default(0) @map("sort_order")
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("navigation_links")
}

model HeroSlide {
  id        String   @id @db.Uuid
  imageUrl  String   @map("image_url")
  ctaLabel  String   @map("cta_label")
  ctaHref   String   @map("cta_href")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("hero_slides")
}

model HeroSideCard {
  id        String   @id @db.Uuid
  eyebrow   String?
  title     String
  imageUrl  String   @map("image_url")
  href      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("hero_side_cards")
}

model TrustFeature {
  id        String   @id @db.Uuid
  icon      String
  title     String
  subtitle  String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("trust_features")
}

model Category {
  id                String                  @id @db.Uuid
  parentId          String?                 @map("parent_id") @db.Uuid
  name              String
  slug              String                  @unique
  description       String?
  imageUrl          String?                 @map("image_url")
  isActive          Boolean                 @default(true) @map("is_active")
  featuredOnHome    Boolean                 @default(false) @map("featured_on_home")
  featuredSortOrder Int                     @default(0) @map("featured_sort_order")
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  parent            Category?               @relation("CategoryToCategory", fields: [parentId], references: [id])
  children          Category[]              @relation("CategoryToCategory")
  homeGroupItems    HomeCategoryGroupItem[]
  products          Product[]

  @@map("categories")
}

model HomeCategoryGroup {
  id        String                  @id @db.Uuid
  title     String
  ctaLabel  String                  @map("cta_label")
  ctaHref   String                  @map("cta_href")
  sortOrder Int                     @default(0) @map("sort_order")
  isActive  Boolean                 @default(true) @map("is_active")
  createdAt DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     HomeCategoryGroupItem[]

  @@map("home_category_groups")
}

model HomeCategoryGroupItem {
  id         String            @id @db.Uuid
  groupId    String            @map("group_id") @db.Uuid
  categoryId String?           @map("category_id") @db.Uuid
  label      String
  imageUrl   String            @map("image_url")
  href       String
  sortOrder  Int               @default(0) @map("sort_order")
  isActive   Boolean           @default(true) @map("is_active")
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  category   Category?         @relation(fields: [categoryId], references: [id])
  group      HomeCategoryGroup @relation(fields: [groupId], references: [id])

  @@map("home_category_group_items")
}

model Product {
  id                   String            @id @db.Uuid
  storeId              String            @map("store_id") @db.Uuid
  categoryId           String?           @map("category_id") @db.Uuid
  slug                 String            @unique
  name                 String
  shortDescription     String?           @map("short_description")
  description          String?
  brand                String?
  currencyCode         String            @default("UGX") @map("currency_code")
  listPrice            Decimal?          @map("list_price") @db.Decimal(12, 2)
  salePrice            Decimal?          @map("sale_price") @db.Decimal(12, 2)
  averageRating        Decimal           @default(0) @map("average_rating") @db.Decimal(3, 2)
  ratingCount          Int               @default(0) @map("rating_count")
  bestsellerLabel      String?           @map("bestseller_label")
  bestsellerCategory   String?           @map("bestseller_category")
  boughtPastMonthLabel String?           @map("bought_past_month_label")
  shippingLabel        String?           @map("shipping_label")
  inStockLabel         String?           @default("In Stock") @map("in_stock_label")
  deliveryLabel        String?           @map("delivery_label")
  returnsLabel         String?           @map("returns_label")
  paymentLabel         String?           @default("Secure transaction") @map("payment_label")
  isPublished          Boolean           @default(false) @map("is_published")
  isFeaturedHome       Boolean           @default(false) @map("is_featured_home")
  homeSortOrder        Int               @default(0) @map("home_sort_order")
  publishedAt          DateTime?         @map("published_at") @db.Timestamptz(6)
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  bullets              ProductBullet[]
  media                ProductMedia[]
  relatedTo            ProductRelation[] @relation("ProductToRelation")
  relatesFrom          ProductRelation[] @relation("RelationToProduct")
  specs                ProductSpec[]
  variants             ProductVariant[]
  category             Category?         @relation(fields: [categoryId], references: [id])
  store                Store             @relation(fields: [storeId], references: [id])
  reviews              Review[]
  wishlistItems        WishlistItem[]

  @@map("products")
}

model ProductMedia {
  id        String           @id @db.Uuid
  productId String           @map("product_id") @db.Uuid
  kind      ProductMediaKind @default(image)
  url       String
  altText   String?          @map("alt_text")
  isPrimary Boolean          @default(false) @map("is_primary")
  sortOrder Int              @default(0) @map("sort_order")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product          @relation(fields: [productId], references: [id])

  @@map("product_media")
}

model ProductVariant {
  id             String   @id @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  sku            String?  @unique
  optionName     String   @default("Size") @map("option_name")
  optionValue    String   @map("option_value")
  price          Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  stockQty       Int      @default(0) @map("stock_qty")
  isDefault      Boolean  @default(false) @map("is_default")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product        Product  @relation(fields: [productId], references: [id])

  @@map("product_variants")
}

model ProductSpec {
  id        String   @id @db.Uuid
  productId String   @map("product_id") @db.Uuid
  specName  String   @map("spec_name")
  specValue String   @map("spec_value")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id])

  @@map("product_specs")
}

model ProductBullet {
  id         String   @id @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  bulletText String   @map("bullet_text")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product    Product  @relation(fields: [productId], references: [id])

  @@map("product_bullets")
}

model ProductRelation {
  id               String              @id @db.Uuid
  productId        String              @map("product_id") @db.Uuid
  relatedProductId String              @map("related_product_id") @db.Uuid
  relationKind     ProductRelationKind @default(related) @map("relation_kind")
  badgeText        String?             @map("badge_text")
  sortOrder        Int                 @default(0) @map("sort_order")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product          Product             @relation("ProductToRelation", fields: [productId], references: [id])
  relatedProduct   Product             @relation("RelationToProduct", fields: [relatedProductId], references: [id])

  @@unique([productId, relatedProductId, relationKind])
  @@map("product_relations")
}

model Review {
  id         String   @id @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  rating     Int
  title      String?
  body       String?
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product    Product  @relation(fields: [productId], references: [id])
  profile    Profile  @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@map("reviews")
}

model Wishlist {
  id        String         @id @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  name      String         @default("Default")
  isDefault Boolean        @default(false) @map("is_default")
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     WishlistItem[]
  profile   Profile        @relation(fields: [userId], references: [id])

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @db.Uuid
  wishlistId String   @map("wishlist_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product    Product  @relation(fields: [productId], references: [id])
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id])

  @@unique([wishlistId, productId])
  @@map("wishlist_items")
}

enum UserRole {
  customer
  staff
  admin
}

enum NavLinkKind {
  top
  quick
}

enum ProductMediaKind {
  image
  video
}

enum ProductRelationKind {
  related
  upsell
  cross_sell
}
